# .env.example — copy to .env and fill in API keys before running.
# Three deployment modes share the same code; switch via env only.

# ============================================================================
# Server
# ============================================================================
APP_HOST=127.0.0.1          # set to 0.0.0.0 for cloud deploy (behind a reverse proxy)
APP_PORT=8090
JOBS_ROOT=./data/jobs       # per-job artifacts live here

# Optional HTTP Basic auth gate. Active only when BOTH are set — leave
# blank for local dev. Required for any public cloud deploy (otherwise
# anyone hitting the URL can spend your OpenAI key via /process).
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASS=

# ============================================================================
# Mode C — Cloud (default; v1 acceptance target)
# ============================================================================
EMBED_BACKEND=jina_v4
JINA_API_KEY=                       # required for Mode C
JINA_MODEL=jina-embeddings-v4
JINA_EMBED_BATCH=64

LLM_BASE_URL=https://api.deepseek.com
LLM_PATH_CHAT=/v1/chat/completions
LLM_API_KEY=                        # required for Mode C
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=2048
LLM_INCLUDE_USAGE=1                 # set to 0 for providers that 400 on stream_options

VISION_BASE_URL=https://api.openai.com
VISION_PATH_CHAT=/v1/chat/completions
VISION_API_KEY=                     # required for Mode C
VISION_MODEL=gpt-4o-mini
VISION_MAX_TOKENS=300
VISION_INCLUDE_USAGE=1              # set to 0 for providers that 400 on stream_options

REFINE_MAX_IN_FLIGHT=4
CAPTION_MAX_IN_FLIGHT=16
WHISPER_FALLBACK=0                  # set to 1 to transcribe locally when YouTube captions are unavailable
WHISPER_MODEL=base.en               # faster-whisper model id; tiny.en/base.en/small.en/medium.en/large-v3

# ============================================================================
# Mode A — Local (Macbook + qwen-studio + mlx_clip). UNTESTED in v1.
# Uncomment this block (and comment Mode C above) to try Mode A.
# ============================================================================
# EMBED_BACKEND=mlx_clip
# MLX_CLIP_MODEL=openai/clip-vit-base-patch32
# MLX_CLIP_CACHE_DIR=                # empty → ~/.cache/video-to-steps/mlx_clip/<model-slug>
#
# LLM_BASE_URL=http://127.0.0.1:8766
# LLM_PATH_CHAT=/chat
# LLM_API_KEY=                       # qwen-studio ignores; can be blank
# LLM_MODEL=qwen2.5-coder            # whatever qwen-studio is serving
# LLM_MAX_TOKENS=80000               # Mode A note: reasoning models (DeepSeek v4)
#                                    # share max_tokens between their <think> trace
#                                    # and the visible JSON; outline of a ~10-min
#                                    # video can need 30k+ before the JSON closes.
#                                    # No cost concern locally — bound is wall-clock.
# LLM_INCLUDE_USAGE=0                # qwen-studio is raw-text SSE; no usage chunk
#
# VISION_BASE_URL=http://127.0.0.1:8766
# VISION_PATH_CHAT=/chat
# VISION_API_KEY=
# VISION_MODEL=qwen-vl
# VISION_INCLUDE_USAGE=0

# ============================================================================
# Mode B — Hybrid (MLX CLIP locally + cloud LLM + cloud vision). UNTESTED in v1.
# Same as Mode C but with EMBED_BACKEND=mlx_clip.
# ============================================================================

# ============================================================================
# Mode D — Single-key (OpenAI only). Recommended for cloud / non-technical
# deploys: one key covers chat, vision, AND embeddings. EMBED_BACKEND
# `vision_caption` captions every kept frame with the vision LLM and embeds
# the caption text — so no separate multimodal-embedding provider is
# needed. Trade-off: ~3–10× more vision-LLM calls than Mode C on long
# videos. Comment out Mode C above, uncomment this block.
# ============================================================================
# EMBED_BACKEND=vision_caption
# TEXT_EMBED_BASE_URL=                 # blank → reuse VISION_BASE_URL (single OpenAI account)
# TEXT_EMBED_PATH=/v1/embeddings
# TEXT_EMBED_API_KEY=                  # blank → reuse VISION_API_KEY
# TEXT_EMBED_MODEL=text-embedding-3-small
#
# LLM_BASE_URL=https://api.openai.com
# LLM_PATH_CHAT=/v1/chat/completions
# LLM_API_KEY=${OPENAI_API_KEY}        # set OPENAI_API_KEY in the env / Space secret
# LLM_MODEL=gpt-4o-mini
# LLM_MAX_TOKENS=4096
# LLM_INCLUDE_USAGE=1
#
# VISION_BASE_URL=https://api.openai.com
# VISION_PATH_CHAT=/v1/chat/completions
# VISION_API_KEY=${OPENAI_API_KEY}
# VISION_MODEL=gpt-4o-mini
# VISION_INCLUDE_USAGE=1
